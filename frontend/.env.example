# Frontend data source mode.
# mock: use local mock services in src/services/mockServices.ts
# http: use Spring Boot APIs through src/services/httpServices.ts
# mixed: choose mock/http per module below
VITE_API_MODE=mixed

# Spring Boot backend base URL. Used when VITE_API_MODE=mixed or http.
VITE_API_BASE_URL=http://localhost:8080

# Module switches used only when VITE_API_MODE=mixed.
# Defaults in code: auth=http, all business modules=mock.
VITE_AUTH_API_MODE=http
VITE_DASHBOARD_API_MODE=mock
VITE_SPEAKING_API_MODE=http
VITE_VOCABULARY_API_MODE=mock
VITE_GRAMMAR_API_MODE=mock
VITE_PROFILE_API_MODE=mock
